# Maintainer: Norbert Preining <norbert@preining.info>
pkgname=intel-lpmd
pkgver=0.1.0
pkgrel=6
pkgdesc="Intel Low Power Mode Daemon"
arch=('x86_64')
url="https://github.com/cachyos/$pkgname"
license=('GPL-2.0-or-later')
makedepends=(
  git
  automake
  autoconf-archive
  gtk-doc
  glib2-devel
  systemd
)
depends=(
  glib2
  glibc
  libnl
  libxml2
  polkit
  systemd-libs
  upower
)
source=(git+${url}.git#commit=f25403fa80cbd1734ecbca553232ee38cfc8dfd7)
sha256sums=('0572954dfc86d7b716957fce812e53466fc00f117f550011c68c358cb21167c1')

prepare() {
	cd "$pkgname"
	./autogen.sh prefix=/usr sysconfdir=/etc sbindir=/usr/bin
}

build() {
	cd "$pkgname"
	make
}

package() {
	cd "$pkgname"
	DESTDIR="$pkgdir" make install
	install -Dm 644 -t "${pkgdir}/usr/share/doc/${pkgname}" "$srcdir/${pkgname}"/README.md
	install -Dm 644 -t "${pkgdir}/usr/share/doc/${pkgname}" "$srcdir/${pkgname}"/doc/WLT_proxy.md
}
